@model Budget.domain.Models.Transaction

@{
    ViewData["Title"] = "Add Transaction";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="form-page">
    <div class="form-card">
        <div class="form-header">
            <h2>Add Transaction</h2>
            <a asp-controller="Dashboard" asp-action="Index" class="back-link">← Back to Dashboard</a>
        </div>

        <form asp-action="Create" method="post" class="transaction-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Type"></label>
                <select asp-for="Type" asp-items="ViewBag.TransactionTypes" class="form-control"></select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Amount"></label>
                <input asp-for="Amount" class="form-control" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Category"></label>
                <select asp-for="Category" class="form-control" id="categoryDropdown">
                    @foreach (var item in ViewBag.Categories)
                    {
                        <option value="@item">@item</option>
                    }
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Date"></label>
                <input asp-for="Date" type="date" class="form-control" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="save-btn">Save Transaction</button>
                <a asp-controller="Dashboard" asp-action="Index" class="cancel-btn">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const typeDropdown = document.querySelector('[name="Type"]');
        const categoryDropdown = document.getElementById('categoryDropdown');

        const expenseCategories = [
            "Food", "Transport", "Housing", "Entertainment",
            "Shopping", "Health", "Education", "Other"
        ];

        const incomeCategories = [
            "Salary", "Freelance", "Investment", "OtherIncome"
        ];

        function updateCategories() {
            const selectedType = typeDropdown.value;

            categoryDropdown.innerHTML = "";

            let categories = selectedType === "Income"
                ? incomeCategories
                : expenseCategories;

            categories.forEach(cat => {
                let option = document.createElement("option");
                option.value = cat;
                option.text = cat.replace(/([A-Z])/g, ' $1').trim();
                categoryDropdown.appendChild(option);
            });
        }

        typeDropdown.addEventListener("change", updateCategories);

        updateCategories();
    </script>
}